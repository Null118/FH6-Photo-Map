generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  draft
  pending
  approved
  rejected
  archived
}

enum UserRole {
  admin
  user
}

model Location {
  id           String       @id @default(cuid())
  ownerId      String?
  title        String
  description  String       @default("")
  mapImageKey  String       @default("FH_6.jpg")
  x            Float
  y            Float
  coverPhotoId String?
  isPublished  Boolean      @default(false)
  status       ReviewStatus @default(draft)
  owner        User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  photos       Photo[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([ownerId])
}

model Photo {
  id           String       @id @default(cuid())
  locationId   String
  ownerId      String?
  title        String
  description  String       @default("")
  imagePath    String
  sortOrder    Int          @default(0)
  isPublished  Boolean      @default(false)
  status       ReviewStatus @default(draft)
  cameraBody   String?
  lens         String?
  focalLength  String?
  aperture     String?
  shutterSpeed String?
  iso          String?
  shotAt       DateTime?
  customMeta   Json?
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  owner        User?        @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([locationId])
  @@index([ownerId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  passwordHash String
  role         UserRole @default(user)
  locations    Location[]
  photos       Photo[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
