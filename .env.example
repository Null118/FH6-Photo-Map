# PostgreSQL connection string from Supabase, Neon, Railway, or another provider.
DATABASE_URL="postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require"

# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# Supabase Storage settings. Leave all four unset for local filesystem uploads.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
SUPABASE_STORAGE_BUCKET="fh6-photos"
SUPABASE_STORAGE_PUBLIC_URL="https://your-project-ref.supabase.co/storage/v1/object/public/fh6-photos"
